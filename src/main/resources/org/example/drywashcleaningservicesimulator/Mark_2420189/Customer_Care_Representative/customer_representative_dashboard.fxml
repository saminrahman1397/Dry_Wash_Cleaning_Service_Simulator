<AnchorPane fx:id="CustomerCareDashboard" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: 000;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.Mark_2420189.Customer_Care_Representative.CustomerCareDashboard_Controller">
    <children>
        <Text layoutX="120.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Care Representative Dashboard" wrappingWidth="426.0">
            <font>
                <Font size="22.0" />
            </font>
        </Text>


        <Button fx:id="addComplaintButton" layoutX="34.0" layoutY="85.0" mnemonicParsing="false" onAction="#addComplaintONA" prefHeight="32.0" prefWidth="237.0" text="Add New Customer Complaint" />
        <Button fx:id="editComplaintButton" layoutX="330.0" layoutY="85.0" mnemonicParsing="false" onAction="#editComplaintONA" prefHeight="32.0" prefWidth="237.0" text="Edit Complaint Description" />


        <Button fx:id="deleteComplaintButton" layoutX="34.0" layoutY="142.0" mnemonicParsing="false" onAction="#deleteComplaintONA" prefHeight="32.0" prefWidth="237.0" text="Delete Resolved Complaint" />
