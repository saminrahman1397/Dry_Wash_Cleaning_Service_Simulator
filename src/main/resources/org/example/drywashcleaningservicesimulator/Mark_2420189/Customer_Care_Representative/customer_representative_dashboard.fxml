        <Button fx:id="viewAllComplaintsButton" layoutX="34.0" layoutY="199.0" mnemonicParsing="false" onAction="#viewAllComplaintsONA" prefHeight="32.0" prefWidth="237.0" text="View All Complaints" />
        <Button fx:id="deleteRequestButton" layoutX="330.0" layoutY="199.0" mnemonicParsing="false" onAction="#deleteRequestONA" prefHeight="32.0" prefWidth="237.0" text="Delete Canceled Request" />

        <Button fx:id="addFollowUpButton" layoutX="34.0" layoutY="256.0" mnemonicParsing="false" onAction="#addFollowUpONA" prefHeight="32.0" prefWidth="237.0" text="Add Follow-Up Note" />
        <Button fx:id="editContactButton" layoutX="330.0" layoutY="256.0" mnemonicParsing="false" onAction="#editContactONA" prefHeight="32.0" prefWidth="237.0" text="Edit Customer Contact Number" />
