<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="OperationsCoordinatorDashboard" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.Mark_2420189.OperationsCoordinator.OperationsCoordinatorDashboardController">
    <children>
        <Text layoutX="148.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Operations Coordinator Dashboard" textAlignment="CENTER" wrappingWidth="350.0">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Text>

        <!-- Goal 1: Add Location -->
        <Button fx:id="addLocationButton" layoutX="11.0" layoutY="100.0" mnemonicParsing="false" onAction="#addLocationONA" prefHeight="40.0" prefWidth="260.0" text="Add New Cleaning Location">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 2: Edit Location -->
        <Button fx:id="editLocationButton" layoutX="331.0" layoutY="100.0" mnemonicParsing="false" onAction="#editLocationONA" prefHeight="40.0" prefWidth="260.0" text="Edit Existing Location">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 3: Delete Location -->
        <Button fx:id="deleteLocationButton" layoutX="11.0" layoutY="160.0" mnemonicParsing="false" onAction="#deleteLocationONA" prefHeight="40.0" prefWidth="260.0" text="Delete Cleaning Location">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 4: Add Staff -->
        <Button fx:id="addStaffButton" layoutX="331.0" layoutY="160.0" mnemonicParsing="false" onAction="#addStaffONA" prefHeight="40.0" prefWidth="260.0" text="Add New Staff Member">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 5: Edit Staff Assignment -->
        <Button fx:id="editStaffAssignmentButton" layoutX="11.0" layoutY="220.0" mnemonicParsing="false" onAction="#editStaffAssignmentONA" prefHeight="40.0" prefWidth="260.0" text="Edit Staff Assignment for Location">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 7: Daily Summary Report -->
        <Button fx:id="dailySummaryReportButton" layoutX="331.0" layoutY="220.0" mnemonicParsing="false" onAction="#dailySummaryReportONA" prefHeight="40.0" prefWidth="260.0" text="View Daily Summary Report">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Goal 8: Staff Availability -->
        <Button fx:id="staffAvailabilityButton" layoutX="11.0" layoutY="280.0" mnemonicParsing="false" onAction="#staffAvailabilityONA" prefHeight="40.0" prefWidth="260.0" text="Monitor &amp; Update Staff Availability">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Delete Staff -->
        <Button fx:id="deleteStaffButton" layoutX="331.0" layoutY="280.0" mnemonicParsing="false" onAction="#deleteStaffONA" prefHeight="40.0" prefWidth="260.0" text="Delete Staff Member">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>

        <!-- Logout Button -->
        <Button fx:id="logoutButton" layoutX="498.0" layoutY="350.0" mnemonicParsing="false" onAction="#logoutONA" prefHeight="35.0" prefWidth="90.0" text="Logout">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
