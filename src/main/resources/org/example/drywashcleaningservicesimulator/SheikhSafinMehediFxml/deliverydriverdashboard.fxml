<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.deliverydriverdashboardController">
   <children>
      <Label layoutX="14.0" layoutY="-17.0" prefHeight="93.0" prefWidth="262.0" text="Delivery Driver Dashboard">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Button layoutX="52.0" layoutY="64.0" mnemonicParsing="false" onAction="#viewScheduleOnActionButton" text="View Schedule" />
      <Button layoutX="226.0" layoutY="64.0" mnemonicParsing="false" onAction="#deliveryDriverOnActionButton" text="Delivery History" />
      <Button layoutX="393.0" layoutY="64.0" mnemonicParsing="false" onAction="#dailyReportOnActionButton" text="Daily Report" />
      <TableView fx:id="deliveryDriverTableView" layoutX="14.0" layoutY="106.0" prefHeight="200.0" prefWidth="555.0">
        <columns>
          <TableColumn fx:id="orderIDTableColumn" prefWidth="75.0" text="Order ID" />
          <TableColumn fx:id="customerNameTableColumn" prefWidth="142.0" text="Customer Name" />
            <TableColumn fx:id="addressTableColumn" prefWidth="146.0" text="Address" />
            <TableColumn fx:id="timeSlotTableColumn" prefWidth="83.0" text="Time Slot" />
            <TableColumn fx:id="statusTableColumn" prefWidth="108.0" text="Status" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
