<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.sheikhsafinmehedi.deliverydriverworkController">
   <children>
      <Label layoutX="14.0" prefHeight="49.0" prefWidth="157.0" text="Delivery Details">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="61.0" layoutY="50.0" prefHeight="17.0" prefWidth="347.0" text="Order ID:" />
      <Label layoutX="61.0" layoutY="113.0" prefHeight="17.0" prefWidth="324.0" text="Address: " />
      <Label layoutX="50.0" layoutY="169.0" prefHeight="17.0" prefWidth="335.0" text="Total Cost: " />
      <Label layoutX="20.0" layoutY="84.0" prefHeight="17.0" prefWidth="335.0" text="Customer Name: " />
      <Label layoutX="14.0" layoutY="141.0" prefHeight="17.0" prefWidth="294.0" text="Payment Method:" />
      <TextField fx:id="orderIDTextField" layoutX="113.0" layoutY="46.0" />
      <TextField fx:id="customerNameTextField" layoutX="113.0" layoutY="80.0" />
      <TextField fx:id="addressTextField" layoutX="113.0" layoutY="109.0" />
      <TextField fx:id="paymentMethodTextField" layoutX="113.0" layoutY="137.0" />
      <TextField fx:id="totalCostTextField" layoutX="113.0" layoutY="165.0" />
      <Button layoutX="35.0" layoutY="200.0" mnemonicParsing="false" onAction="#startDeliveryOnActionButton" text="Start Delivery" />
      <Button layoutX="192.0" layoutY="201.0" mnemonicParsing="false" onAction="#confirmDeliveryOnActionButton" text="Confirm Delivery" />
      <Button layoutX="337.0" layoutY="201.0" mnemonicParsing="false" onAction="#confirmPickupOnActionButton" text="Confirm Pickup" />
      <Label layoutX="16.0" layoutY="248.0" text="Change Amount:" />
      <TextField fx:id="changeAmountTextField" layoutX="118.0" layoutY="244.0" />
      <Button layoutX="41.0" layoutY="301.0" mnemonicParsing="false" onAction="#calculateChangeOnActionButton" text="Calculate Change" />
      <Button layoutX="183.0" layoutY="301.0" mnemonicParsing="false" onAction="#submitPaymentOnActionButton" text="Submit Payment" />
   </children>
</AnchorPane>
