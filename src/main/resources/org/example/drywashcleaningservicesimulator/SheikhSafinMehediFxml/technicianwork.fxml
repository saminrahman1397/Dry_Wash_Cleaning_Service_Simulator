<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="826.0" prefWidth="658.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.technicianworkController">
   <children>
      <Label layoutX="14.0" layoutY="14.0" prefHeight="34.0" prefWidth="172.0" text="Order Details">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Button layoutX="14.0" layoutY="413.0" mnemonicParsing="false" onAction="#updateSettingOnActionButton" text="Update Stage " />
      <Button layoutX="216.0" layoutY="413.0" mnemonicParsing="false" onAction="#markBatchCompleteOnActionButton" text="Mark Batch Complete" />
      <Button layoutX="466.0" layoutY="413.0" mnemonicParsing="false" onAction="#reportDamageOnActionButton" text="Report Damage" />
      <TableView fx:id="orderDetailsTableView" layoutX="12.0" layoutY="56.0" prefHeight="200.0" prefWidth="634.0">
        <columns>
          <TableColumn fx:id="garmentTypeTableColumn" prefWidth="141.0" text="Garment Type" />
          <TableColumn fx:id="quantityTableColumn" prefWidth="104.0" text="Quantity" />
            <TableColumn fx:id="serviceTypeTableColumn" prefWidth="269.0" text="Service Type" />
            <TableColumn fx:id="currentStageTableColumn" prefWidth="119.0" text="Current Stage" />
        </columns>
      </TableView>
      <ComboBox fx:id="selectNewStageComboBox" layoutX="12.0" layoutY="280.0" prefWidth="150.0" promptText="Select New Stage" />
      <TextArea fx:id="cleaningNotesTextArea" layoutX="14.0" layoutY="458.0" prefHeight="78.0" prefWidth="589.0" text="Cleaning Notes:" />
      <Button layoutX="14.0" layoutY="562.0" mnemonicParsing="false" onAction="#saveNotesOnActionButton" text="Save Notes" />
   </children>
</AnchorPane>
