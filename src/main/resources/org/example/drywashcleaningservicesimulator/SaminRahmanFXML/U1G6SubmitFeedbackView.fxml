<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.drywashcleaningservicesimulator.SaminRahman.U1G6SubmitFeedbackViewController">
   <children>
      <Label alignment="CENTER" layoutX="192.0" layoutY="34.0" prefHeight="67.0" prefWidth="216.0" text="SUBMIT FEEDBACK!" underline="true">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Label>
      <Label layoutX="70.0" layoutY="93.0" text="What would you rate our service?" />
      <RadioButton fx:id="oneStarRadioButton" layoutX="70.0" layoutY="117.0" mnemonicParsing="false" text="1 stars" />
      <RadioButton fx:id="twoStarRadioButton" layoutX="70.0" layoutY="134.0" mnemonicParsing="false" text="2 stars" />
      <RadioButton fx:id="threeStarRadioButton" layoutX="70.0" layoutY="151.0" mnemonicParsing="false" text="3 stars" />
      <RadioButton fx:id="fourStarRadioButton" layoutX="70.0" layoutY="168.0" mnemonicParsing="false" text="4 stars" />
      <RadioButton fx:id="fiveStarRadioButton" layoutX="70.0" layoutY="185.0" mnemonicParsing="false" text="5 stars" />
      <Label layoutX="300.0" layoutY="93.0" text="Any Comments? " />
      <TextArea fx:id="commentsTextArea" layoutX="300.0" layoutY="110.0" prefHeight="67.0" prefWidth="200.0" />
      <Label layoutX="70.0" layoutY="226.0" text="Will you recommend others?" />
      <RadioButton fx:id="yesRadioButton" layoutX="81.0" layoutY="252.0" mnemonicParsing="false" text="YES" />
      <RadioButton fx:id="noRadioButton" layoutX="81.0" layoutY="269.0" mnemonicParsing="false" text="NO" />
      <RadioButton fx:id="maybeRadioButton" layoutX="81.0" layoutY="286.0" mnemonicParsing="false" text="MAYBE" />
      <Button layoutX="248.0" layoutY="257.0" mnemonicParsing="false" onAction="#submitFeedbackOnActionButton" text="Submit Feedback" />
      <Button layoutX="466.0" layoutY="341.0" mnemonicParsing="false" onAction="#dashboardOnActionButton" text="Dashboard" />
   </children>
</AnchorPane>
