        </columns>
      </TableView>
      <Button layoutX="260.0" layoutY="243.0" mnemonicParsing="false" onAction="#myOrdersOnActionButton" text="My Orders" />
      <Label layoutX="32.0" layoutY="286.0" text="Order ID to Cancel : " />
